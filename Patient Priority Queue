
#include <iostream>
using namespace std;

struct Node {
    int id;
    string name;
    int severity;
    Node* next;
};

class PatientQueue {
    Node* head;

public:
    PatientQueue() { head = NULL; }

    void enqueue(int id, string name, int severity) {
        Node* n = new Node{id,name,severity,NULL};

        if(!head || severity > head->severity) {
            n->next = head;
            head = n;
            return;
        }

        Node* temp = head;
        while(temp->next && temp->next->severity >= severity)
            temp = temp->next;

        n->next = temp->next;
        temp->next = n;
    }

    void dequeue() {
        if(!head) return;
        Node* temp = head;
        head = head->next;
        delete temp;
    }

    void display() {
        Node* temp = head;
        while(temp) {
            cout << temp->name << "(" << temp->severity << ") ";
            temp = temp->next;
        }
        cout << endl;
    }
};

int main() {
    PatientQueue q;
    q.enqueue(1,"Ali",5);
    q.enqueue(2,"Ahmed",8);

    q.display();
}
