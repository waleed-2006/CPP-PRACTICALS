#include <iostream>
using namespace std;

struct Student {
    int roll;
    string name;
    float marks;
};

int main() {
    Student s[5];

    for (int i = 0; i < 5; i++) {
        cout << "enter Roll Number: ";
        cin >> s[i].roll;
        cout << "Enter the name: ";
        cin >> s[i].name;
        cout << "enter marks please";
        cin>> s[i].marks;
    }

    cout << "Students > 75 marks:\n";
    for (int i = 0; i < 5; i++) {
        if (s[i].marks > 75)
            cout << s[i].name << endl;
    }
}
